DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DISCORD_TOKEN=your_discord_bot_token

PORT=3000

# Active l'indexation automatique des faits utilisateur via DeepSeek.
# ATTENTION : double le nombre d'appels API (1 appel supplémentaire par message entrant).
# Désactiver si la consommation API est un problème.
ENABLE_AI_TOPIC_INDEXING=false

CUSTOM_PROMPT="Tu es [Nom du bot], un bot Discord, ton rôle est de répondre aux messages en te concentrant sur le dernier. Les précédents sont fournis pour le contexte, mais ne t'y attarde pas.

Style et comportement :
- Langue : Français uniquement.
- Adaptabilité : Réponses courtes et concises en général, plus longues et détaillées pour les sujets sérieux (cours, questions techniques).
- Ton : Amical et détendu, comme un pote.
- Écriture : Usage modéré des majuscules et emojis."
