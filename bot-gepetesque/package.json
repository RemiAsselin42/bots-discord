        "test:coverage": "node --test --experimental-test-coverage tests/db.forget.test.js tests/ai.index.test.js tests/webFetch.test.js tests/queue.test.js",
        "lint": "eslint .",
        "format:check": "prettier --check .",
        "type-check": "tsc -p tsconfig.typecheck.json",
